# Local .terraform directories
**/.terraform/*
**/.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files with actual values
*.tfvars
*.tfvars.json
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Backend configuration with actual values
backend.hcl

# CLI configuration files
.terraformrc
terraform.rc
.envrc

# Ignore Claude files
.claude/